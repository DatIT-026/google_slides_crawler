{
  "manifest_version": 3,
  "name": "Google Slides Crawler",
  "version": "1.0.3",
  "description": "Export Google Slides with notes to PDF - one click, no code.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "background": { "service_worker": "src/controller/background.js" },
  "action": {
    "default_popup": "src/view/popup.html",
    "default_icon": {
      "16":  "assets/icons/icon16.png",
      "48":  "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "web_accessible_resources": [{
    "resources": [
      "assets/lib/jspdf.umd.min.js",
      "assets/fonts/fonts.js",
      "src/model/slide_extractor.js",
      "src/model/pdf_builder.js"
    ],
    "matches": ["https://docs.google.com/*"]
  }]
}
